{
  "name": "social-listeting",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker:build": "tsc -p tsconfig.worker.json",
    "worker:check": "npm run worker:build && node dist/worker/brain.js",
    "worker:once": "npm run worker:build && SOCIAL_LISTENING_RUN_ONCE=true SOCIAL_LISTENING_INGEST_ONLY=true X_SEARCH_MAX_RESULTS=10 node dist/worker/index.js",
    "worker:slack-smoke": "npm run worker:build && node dist/worker/slack-smoke.js",
    "worker": "npm run worker:build && node dist/worker/index.js"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "typescript": "^6.0.3"
  }
}
